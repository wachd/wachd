# Builds the wachd-agent binary — a lightweight k8s-resident binary that
# watches security tool CRDs and forwards findings to central Wachd.
# No Node.js, no web assets — final image is ~25MB.

FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /out/wachd-agent ./cmd/agent

# ── Runtime ───────────────────────────────────────────────────────────────────
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /out/wachd-agent /wachd-agent

USER nonroot
ENTRYPOINT ["/wachd-agent"]
