# Wachd — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# Allowed origin for CORS — set to your dashboard domain in production
# e.g. https://wachd.company.internal
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://wachd:wachd_dev_password@localhost:5432/wachd?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Analysis Backend ──────────────────────────────────────────────────────────
# Options: "ollama" (local, air-gapped) | "openai" (cloud, requires SMB license)
AI_BACKEND=ollama

# Ollama — local, no external calls
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — cloud (SMB/Enterprise license required)
# AI_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── License ───────────────────────────────────────────────────────────────────
# Leave empty for the open-source tier (1 team, 5 users, 1,000 alerts/month)
LICENSE_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=alerts

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Data Sources ──────────────────────────────────────────────────────────────
# GitHub — read-only token with `contents:read` scope
GITHUB_TOKEN=
GITHUB_REPOS=owner/repo1,owner/repo2

# Prometheus
PROMETHEUS_ENDPOINT=http://prometheus:9090

# Loki
LOKI_ENDPOINT=http://loki:3100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
ENVIRONMENT=development
